{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodexTurnChime",
  "version": "0.1.0-beta.2",
  "identifier": "io.github.jgarrick1992.codexturnchime",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "CodexTurnChime",
        "width": 1240,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self'; media-src 'self' asset: data:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Local task status and sound notifications for Codex",
    "longDescription": "Independent local-first task state monitor and customizable sound notifier for Codex.",
    "copyright": "Copyright © 2026 CodexTurnChime contributors",
    "externalBin": ["binaries/codex-turn-chime-hook"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-"
    },
    "windows": {
      "webviewInstallMode": { "type": "skip" },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
